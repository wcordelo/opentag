# OpenTag — Claude Tag on Cloudflare (Slack) + Node AG-UI runtime

# ── Slack (Cloudflare bot Worker — edge/) ───────────────────────────────
# Events API only (no Socket Mode). Set these as wrangler secrets / .dev.vars
# in edge/, and in Slack app Request URLs → your Worker.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...

# ── Agent backend ───────────────────────────────────────────────────────
# Production: Cloudflare Container (opentag-agent) — set on the bot Worker:
#   AGENT_URL=https://opentag-agent.<account>.workers.dev/api/copilotkit/agent/triage/run
# Dev-only local brain:
AGENT_URL=http://localhost:8200/api/copilotkit/agent/triage/run
# AGENT_AUTH_HEADER=Bearer ...
# AGENT_MODEL=openai/gpt-5.5
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# ── Research actors (optional Railway / local Postgres track) ───────────
# DATABASE_URL=postgres://opentag:opentag@localhost:5432/opentag
# AGENT_RESEARCH_URL=http://localhost:8201/api/copilotkit/agent/research/run
# RESEARCH_DELIVERY_URL=http://localhost:8202
# PARALLEL_API_KEY=...
# RESEARCH_MODEL=claude-sonnet-4-20250514
# RESEARCH_FALLBACK_MODEL=gpt-4o
# SLACK_ALLOWED_CHANNEL_IDS=C123,C456
# BLOB_STORAGE_PATH=./data/blobs

# ── Linear MCP ──────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_...
# LINEAR_MCP_URL=https://mcp.linear.app/mcp
LINEAR_TEAM_KEY=Berendo

# ── Notion MCP ──────────────────────────────────────────────────────────
# NOTION_TOKEN=
# NOTION_MCP_AUTH_TOKEN=
# NOTION_MCP_URL=http://127.0.0.1:3001/mcp
# NOTION_MCP_PORT=3001

# ── Cloudflare edge (also see edge/.dev.vars) ───────────────────────────
# ADMIN_SECRET=
# INTERNAL_SECRET=
