    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@notionhq/notion-mcp-server": "^2.2.1",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.3"
  }
