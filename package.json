{
  "name": "opentag",
  "version": "0.2.0",
  "private": true,
  "description": "OpenTag — open-source Claude Tag alternative: Slack agent on Cloudflare (edge/) with Node AG-UI runtime.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx app/index.ts",
    "start": "tsx app/index.ts",
    "runtime": "tsx runtime.ts",
