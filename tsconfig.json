{
  "compilerOptions": {
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "noEmit": true,
    "lib": ["es2022", "dom"],
    "types": ["node"]
  },
  "include": [
    "runtime.ts",
    "runtime-research.ts",
    "worker/**/*.ts",
    "lib/**/*.ts",
    "e2e/research-loop.ts"
  ],
  "exclude": ["node_modules", "agent", "app", "edge"]
}
